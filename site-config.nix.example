# Site Configuration — Fill in YOUR values
# This file is imported by lib/site.nix and provides all site-specific constants.
# Copy to site-config.nix and customize for your environment.

{
  # ── Organization ────────────────────────────────────────────────────────────
  orgName = "myorg";
  domain = "myplatform.example.com";

  # ── SSH Keys (at least one required) ────────────────────────────────────────
  sshKeys = [
    # "ssh-ed25519 AAAAC3... admin@workstation"
  ];

  # ── VLANs ───────────────────────────────────────────────────────────────────
  # Adjust IDs and CIDRs to match your network. The pattern assumes a firewall
  # doing all inter-VLAN routing (like Palo Alto, pfSense, OPNsense).
  vlans = {
    nodes     = { id = 100; cidr = "10.0.0.0/20";    gateway = "10.0.0.1"; };
    edge      = { id = 101; cidr = "10.0.16.0/20";   gateway = "10.0.16.1"; };
    storage   = { id = 102; cidr = "10.0.32.0/20";   gateway = null; };  # east-west only, no firewall routing
    tunnel    = { id = 103; cidr = "10.0.48.0/20";   gateway = "10.0.48.1"; };
    provision = { id = 105; cidr = "10.0.64.0/20";   gateway = null; };  # flat L2, PXE only
    migration = { id = 900; cidr = "10.0.254.0/24";  gateway = null; };  # east-west only, no firewall routing
  };

  # ── MetalLB ─────────────────────────────────────────────────────────────────
  # MetalLB ships in FRR mode by default — it can do both L2 and BGP.
  # See infrastructure/metallb/config.yaml for the L2/BGP examples.
  metallb = {
    addressPool = "10.0.16.0/24";    # Subset of edge VLAN for VIPs
    traefikVip = "10.0.16.10";       # Primary ingress VIP
    interface = "vlan101";            # L2 advertisement interface
    # Optional BGP — uncomment if your upstream router will peer.
    # bgp = {
    #   myASN = 64512;                # K8s cluster ASN (RFC 6996 private)
    #   peerASN = 64513;              # Upstream router ASN
    #   peerAddress = "10.0.16.1";    # Edge VLAN gateway
    # };
  };

  # ── Cilium ──────────────────────────────────────────────────────────────────
  # Cilium is the CNI and replaces kube-proxy. The HelmRelease lives at
  # infrastructure/cilium/helmrelease.yaml — these values document what
  # the defaults are and what you typically override per site.
  cilium = {
    # Pinned version. Bump deliberately after testing — auto-upgrades can
    # break pod networking cluster-wide.
    version = "1.16.19";
    # Cilium MTU should match your pod fabric MTU minus a small headroom.
    # 1500 is the safe default for any 1G fabric. Bump to 8950 if you
    # have a 10G fabric with jumbo frames (9000) configured end-to-end.
    mtu = 1500;
    # Bootstrap apiserver IP for kube-proxy replacement. Must be a real
    # control-plane node IP, not the kubernetes Service VIP.
    k8sServiceHost = "10.0.0.10";
    # Cilium installs node-to-node routes automatically when all nodes
    # are L2-adjacent on the chosen fabric. Set false if you prefer to
    # manage peer routes by hand in node-config.nix.
    autoDirectNodeRoutes = true;
  };

  # ── K3s ─────────────────────────────────────────────────────────────────────
  k3s = {
    clusterCidr = "10.42.0.0/16";
    serviceCidr = "10.43.0.0/16";
    nodeCidrMask = 24;                # /24 per node (256 pod IPs each)
    # Token: generate with `openssl rand -hex 32` and place in /etc/k3s-token on each node
    #
    # NOTE: hosts/worker/configuration.nix disables flannel, kube-proxy,
    # helm-controller, traefik, and servicelb out of the box. Cilium
    # replaces flannel + kube-proxy; Flux replaces helm-controller; the
    # Traefik HelmRelease replaces the in-tree chart.
  };

  # ── Nodes ───────────────────────────────────────────────────────────────────
  # Define your nodes here. Each node gets a per-node config in hosts/worker/node-configs/
  nodes = {
    node-1 = {
      hardware = "Dell R430";         # For documentation
      k8s = "10.0.0.10";             # VLAN 100 (primary)
      edge = "10.0.16.2";            # VLAN 101 (MetalLB)
      storage = "10.0.32.10";        # VLAN 102 (10G fabric)
      role = "server";               # "server" (control-plane + etcd) or "agent"
    };
    node-2 = {
      hardware = "Dell R430";
      k8s = "10.0.0.11";
      edge = "10.0.16.11";
      storage = "10.0.32.11";
      role = "server";
    };
    node-3 = {
      hardware = "AMD EPYC";
      k8s = "10.0.0.12";
      edge = "10.0.16.20";
      storage = "10.0.32.12";
      role = "server";
      gpu = true;                     # NVIDIA GPU passthrough
    };
  };

  # ── PXE Provisioning (optional) ────────────────────────────────────────────
  provisioning = {
    serverIP = "10.0.64.10";          # PXE/DHCP/TFTP server (usually node-1)
    dhcpRange = { start = "10.0.64.100"; end = "10.0.64.254"; };
    httpPort = 9080;
  };

  # ── TLS ─────────────────────────────────────────────────────────────────────
  tls = {
    email = "admin@example.com";      # Let's Encrypt registration email
  };
}

# Example: First control-plane node (init controller — bootstraps the cluster)
{
  hostname = "node-1";
  hostId = "a1b2c3d4";  # head -c4 /dev/urandom | od -A none -t x4 | tr -d ' '

  primaryInterface = "eno1";
  primaryAddress = "10.0.0.10/20";
  primaryGateway = "10.0.0.1";

  enable10g = true;
  sfpInterfaces = [ "enp5s0f0" "enp5s0f1" ];
  storageAddress = "10.0.32.10/20";
  migrationAddress = "10.0.254.10/24";

  k0sRole = "controller+worker";
  k0sTokenFile = "";  # Empty = init controller (first node bootstraps the cluster)
  # After bootstrap, generate join tokens for other nodes:
  #   k0s token create --role=controller > /etc/k0s/controller-token
  #   k0s token create --role=worker > /etc/k0s/worker-token

  enableEdge = true;
  edgeInterface = "eno3";
  edgeAddress = "10.0.16.2/20";
  tunnelAddress = "10.0.48.10/20";

  enableKvm = true;
  enableWindowsBridge = true;
  bridgeInterface = "eno2";

  enableZfs = true;
  zfsPools = [ "tank" ];

  sshKeys = [
    # "ssh-ed25519 AAAAC3... admin@workstation"
  ];
}

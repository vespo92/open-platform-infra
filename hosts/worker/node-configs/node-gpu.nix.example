# Example: GPU node (different NIC layout, NVMe pool)
{
  hostname = "node-gpu";
  hostId = "c9d0e1f2";

  primaryInterface = "eno1";
  primaryAddress = "10.0.0.12/20";
  primaryGateway = "10.0.0.1";

  enable10g = true;
  sfpInterfaces = [ "enp2s0f0" "enp2s0f1" ];  # Different PCI slot than Dell R430s
  storageAddress = "10.0.32.12/20";
  migrationAddress = "10.0.254.12/24";

  k0sRole = "controller+worker";
  k0sTokenFile = "/etc/k0s/join-token";  # Controller join token from init node

  enableEdge = true;
  edgeInterface = "eno2";  # Different chassis layout — eno2 not eno3
  edgeAddress = "10.0.16.20/20";
  tunnelAddress = "10.0.48.20/20";

  enableKvm = false;  # GPU node, not a hypervisor
  enableWindowsBridge = false;

  enableZfs = true;
  zfsPools = [ "fastpool" ];  # NVMe pool, not HDD

  enableGpu = true;
  nodeClass = "gpu";

  sshKeys = [
    # "ssh-ed25519 AAAAC3... admin@workstation"
  ];
}
